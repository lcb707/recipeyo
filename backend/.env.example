# Backend (.env) - 복사 후 .env 로 저장하고 값 채우기
# 실제 비밀번호/키는 .env에만 두고, .env는 Git에 올리지 마세요.

# Django
DEBUG=1
DJANGO_SECRET_KEY=your-secret-key-min-50-chars
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# MySQL (Docker 서비스명 또는 localhost)
MYSQL_DATABASE=dj_DB
MYSQL_USER=sky
MYSQL_PASSWORD=your-db-password
MYSQL_HOST=mysql_dj
MYSQL_PORT=3306

# Redis
REDIS_PASSWORD=
REDIS_HOST=redis
REDIS_PORT=6379

# 이메일 (Gmail 등 SMTP, 선택)
# EMAIL_HOST_USER=your@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# Superuser 생성용 (선택, manage.py createsuperuser 대안)
# DJANGO_SUPERUSER_EMAIL=admin@example.com
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_PASSWORD=admin-password
